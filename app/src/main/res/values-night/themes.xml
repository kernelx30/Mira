<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Operit" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/mira_teal_light</item>
        <item name="colorPrimaryVariant">@color/mira_teal_dark</item>
        <item name="colorOnPrimary">@color/mira_ink</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/mira_rose</item>
        <item name="colorSecondaryVariant">@color/mira_gold</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Declare support for drawing into the status bar / display cutout area. -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>
</resources>
